# Copy this file outside the repository and inject it through the deployment platform.
APP_ENV=production
HTTP_BIND_IP=0.0.0.0
HTTP_PORT=80
HTTPS_BIND_IP=0.0.0.0
HTTPS_PORT=443
# Host paths to the PEM certificate chain and its private key.
TLS_CERT_FILE=/etc/letsencrypt/live/example.com/fullchain.pem
TLS_KEY_FILE=/etc/letsencrypt/live/example.com/privkey.pem

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=
ACCESS_TOKEN_EXPIRE_SECONDS=604800

# Use a dedicated least-privilege database account. URL-encode special characters.
DATABASE_URL=mysql+pymysql://yunyao_app:CHANGE_ME@db:3306/yunyao?charset=utf8mb4
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Production must use explicit HTTPS origins. Never use *.
CORS_ORIGINS=https://yunyao.example.com
ALLOW_DEV_CORS=0
ADMIN_USER_IDS=
ADMIN_ALLOWED_IPS=
MAX_PAGE_SIZE=50
LOG_LEVEL=INFO
LOG_TO_FILE=0
SLOW_SQL_MS=500
# Optional Sentry-compatible error tracking; leave empty to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=1
TRUSTED_PROXY_IPS=172.16.0.0/12

# Fernet key for user PII. Generate with Fernet.generate_key().decode().
PERSONAL_DATA_ENCRYPTION_KEY=

# High-entropy passphrase used to derive the recipe encryption key.
RECIPE_ENCRYPT_KEY=

# Preferred keyring: JSON object mapping key id to a Fernet key.
ENCRYPTION_KEYS=
ENCRYPTION_ACTIVE_KEY_ID=primary

# Alternative to the two variables above: mount the existing key as a secret file.
ENCRYPTION_KEY_FILE=

# Inject through a cloud secret manager / Docker secret; never app_settings.
SMTP_PASSWORD_FILE=/run/secrets/smtp_password
SMTP_PASSWORD_SECRET_FILE=/secure/yunyao/secrets/smtp_password
VERIFICATION_CHANNEL=email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_FROM=
SMTP_USE_SSL=1

# One-time bootstrap administrator. Keep the password in a root-readable file.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD_SECRET_FILE=/secure/yunyao/secrets/initial_admin_password

# Cloud S3-compatible object storage. Create both buckets before deployment.
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://s3-compatible-endpoint.example.com
S3_REGION=replace-with-cloud-region
S3_BUCKET=yunyao-uploads
S3_PRIVATE_BUCKET=yunyao-private
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://cdn-or-public-bucket.example.com

# Optional Baidu OCR integration.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_TOKEN_URL=https://aip.baidubce.com/oauth/2.0/token
BAIDU_OCR_API_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic
